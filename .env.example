# Datenbank
DATABASE_URL='postgresql://user:password@host:5432/dbname'

# NextAuth
NEXTAUTH_SECRET='your-secret-key-here'
NEXTAUTH_URL='http://localhost:3000'

# Supabase (Read-Only Wissensbasis)
NEXT_PUBLIC_SUPABASE_URL='https://your-project.supabase.co'
NEXT_PUBLIC_SUPABASE_ANON_KEY='your-anon-key'

# ============================================
# LLM API (Provider-agnostisch)
# ============================================
# Für Mistral:
LLM_API_URL='https://api.mistral.ai/v1/chat/completions'
LLM_API_KEY='your-mistral-api-key'
LLM_MODEL='mistral-large-latest'
#
# Für OpenAI:
# LLM_API_URL='https://api.openai.com/v1/chat/completions'
# LLM_API_KEY='your-openai-api-key'
# LLM_MODEL='gpt-4o-mini'
#
# Für Abacus.AI (Standard bei Abacus-Hosting):
# ABACUSAI_API_KEY='your-abacus-api-key'
# (LLM_API_URL und LLM_MODEL werden automatisch gesetzt)

# ============================================
# E-Mail (Provider-agnostisch)
# ============================================
# Für Resend (empfohlen für Vercel):
RESEND_API_KEY='your-resend-api-key'
RESEND_FROM_EMAIL='Kompetenzeinschätzung <noreply@your-domain.com>'
#
# Für Abacus.AI Notification API (Standard bei Abacus-Hosting):
# WEB_APP_ID='your-web-app-id'
# NOTIF_ID_PASSWORT_ZURCKSETZEN='your-notification-id'
